ENVIRONMENT=local
APP_NAME=AI Interview Coach
APP_VERSION=0.1.0
DEBUG=false

OPENAI_API_KEY=

AWS_REGION=eu-west-2
S3_BUCKET_NAME=

# Local-only Postgres default (Docker Compose).
DATABASE_URL=postgresql://ai_interview:ai_interview_dev_password@127.0.0.1:5432/ai_interview_coach

# Optional discrete values; if DATABASE_URL is empty and all values below are set,
# settings will construct DATABASE_URL automatically.
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# Comma-separated list for local frontend origins.
ALLOWED_ORIGINS=http://localhost:3000